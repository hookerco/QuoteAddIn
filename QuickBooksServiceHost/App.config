<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <appSettings>
        <!--
          QuickBooks localhost bridge configuration. Environment variables of the same name
          take precedence over these values. All three MUST match the app server:
            QB_BRIDGE_PORT   - must equal the port in the app server's QUOTE_MODULEV2_QB_BRIDGE_URL
            QB_BRIDGE_ORIGIN - the app-server origin echoed via CORS, e.g. http://APPSRV01:8742
            QB_BRIDGE_TOKEN  - must equal the app server's QUOTE_MODULEV2_QB_BRIDGE_TOKEN
          The bridge rejects every request with 403 until QB_BRIDGE_TOKEN is set.
        -->
        <add key="QB_BRIDGE_PORT" value="8788" />
        <add key="QB_BRIDGE_ORIGIN" value="http://APPSRV01:8742" />
        <add key="QB_BRIDGE_TOKEN" value="" />
    </appSettings>
</configuration>
